{
  "name": "@connextable/popbill-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "typecheck": "turbo run typecheck && tsgo -b --noEmit",
    "test": "dotenvx run -- turbo run test",
    "test:coverage": "dotenvx run -- turbo run test:coverage",
    "docs:generate": "jiti ./scripts/generate-sdk-docs.ts",
    "clean": "turbo run clean && del node_modules .turbo"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.52.0",
    "@types/node": "20",
    "@typescript/native-preview": "7.0.0-dev.20260225.1",
    "@vitest/coverage-v8": "4.0.18",
    "del-cli": "7.0.0",
    "globals": "17.3.0",
    "jiti": "2.6.1",
    "nano-staged": "0.9.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.20.3",
    "turbo": "2.8.11",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "nano-staged"
  },
  "nano-staged": {
    "*": [
      "pnpm fmt -- --no-error-on-unmatched-pattern",
      "pnpm lint:fix --"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
