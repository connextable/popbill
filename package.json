{
  "name": "@connextable/popbill-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint --continue=dependencies-successful",
    "lint:fix": "turbo run lint:fix --continue=dependencies-successful",
    "fmt": "turbo run fmt --continue=dependencies-successful",
    "fmt:check": "turbo run fmt:check --continue=dependencies-successful",
    "typecheck": "turbo run typecheck --continue=dependencies-successful && tsgo -b --noEmit",
    "test": "dotenvx run -- turbo run test --continue=dependencies-successful",
    "test:coverage": "dotenvx run -- turbo run test:coverage --continue=dependencies-successful",
    "docs:generate": "jiti ./scripts/generate-sdk-docs.ts",
    "release:verify-manifests": "jiti ./scripts/release/verify-manifests.ts",
    "release:verify-tarballs": "jiti ./scripts/release/verify-tarballs.ts",
    "release:check-readiness": "jiti ./scripts/release/check-readiness.ts",
    "clean": "turbo run clean && del node_modules .turbo"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.65.0",
    "@types/node": "20",
    "@typescript/native-preview": "7.0.0-dev.20260512.1",
    "@vitest/coverage-v8": "4.0.18",
    "del-cli": "7.0.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "nano-staged": "1.0.2",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "turbo": "2.9.12",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "nano-staged"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
