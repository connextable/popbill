{
  "name": "@connextable/popbill-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "typecheck": "turbo run typecheck && tsgo -b --noEmit",
    "test": "dotenvx run -- turbo run test",
    "test:coverage": "dotenvx run -- turbo run test:coverage",
    "docs:generate": "jiti ./scripts/generate-sdk-docs.ts",
    "release:verify-manifests": "jiti ./scripts/release/verify-manifests.ts",
    "release:verify-tarballs": "jiti ./scripts/release/verify-tarballs.ts",
    "release:check-readiness": "jiti ./scripts/release/check-readiness.ts",
    "clean": "turbo run clean && del node_modules .turbo"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.52.0",
    "@types/node": "20",
    "@typescript/native-preview": "7.0.0-dev.20260226.1",
    "@vitest/coverage-v8": "4.0.18",
    "del-cli": "7.0.0",
    "globals": "17.3.0",
    "jiti": "2.6.1",
    "nano-staged": "0.9.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.20.3",
    "turbo": "2.8.11",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "nano-staged"
  },
  "nano-staged": {
    "*": [
      "pnpm fmt -- --no-error-on-unmatched-pattern",
      "pnpm lint:fix --"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
