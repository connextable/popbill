{
  "name": "@connextable/popbill-core",
  "version": "0.1.0",
  "private": true,
  "description": "Internal core modules for Popbill SDKs",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsgo -b --noEmit",
    "typecheck:lib": "tsgo -p tsconfig.lib.json --noEmit",
    "typecheck:test": "tsgo -p tsconfig.test.json --noEmit",
    "clean": "del node_modules dist"
  }
}
