{
  "name": "@connextable/popbill-compat",
  "version": "0.1.0",
  "description": "Compatibility SDK for legacy Popbill interfaces",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./factory": {
      "types": "./dist/factory/index.d.mts",
      "import": "./dist/factory/index.mjs",
      "require": "./dist/factory/index.cjs",
      "default": "./dist/factory/index.mjs"
    },
    "./promise": {
      "types": "./dist/promise/index.d.mts",
      "import": "./dist/promise/index.mjs",
      "require": "./dist/promise/index.cjs",
      "default": "./dist/promise/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:integration": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "del node_modules dist"
  },
  "dependencies": {
    "@connextable/popbill-core": "workspace:*",
    "@connextable/popbill-spec": "workspace:*"
  },
  "sideEffects": false
}