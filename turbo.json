{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "^typecheck"
      ]
    },
    "lint": {},
    "lint:fix": {},
    "fmt": {},
    "fmt:check": {},
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "test:coverage": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}