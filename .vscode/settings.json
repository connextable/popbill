{
  "cSpell.numSuggestions": 0,
  "cSpell.customDictionaries": {
    "words": {
      "name": "Workspace",
      "path": "${workspaceRoot}/.vscode/words.txt",
      "addWords": true,
      "scope": "workspace"
    },
    "custom": true,
    "internal-terms": false
  },
  "js/ts.experimental.useTsgo": true,
  "json.schemaDownload.trustedDomains": {
    "https://turborepo.dev/schema.json": true,
    "https://json.schemastore.org": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.d.ts": "${capture}.d.ts.map",
    "*.js": "${capture}.js.map, ${capture}.min.js",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock"
  },
  "oxc.enable": true,
  "oxc.typeAware": true,
  "editor.formatOnSave": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "typescript.native-preview.tsdk": "./node_modules/@typescript/native-preview"
}
