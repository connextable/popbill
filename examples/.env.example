POPBILL_USE_LOCAL_TIME=true
POPBILL_REQUEST_TIMEOUT_MS=30000
POPBILL_ACCEPT_ENCODING=gzip

POPBILL_COUNTERPART_CORP_NUM=8888888888
POPBILL_RECEIVER_EMAIL=test@example.com

POPBILL_SENDER_PHONE=07043042991
POPBILL_RECEIVER_PHONE=01043042991
POPBILL_SENDER_FAX=07043042991
POPBILL_RECEIVER_FAX=07043042991

# Statement attach/detach use cases are skipped when this is empty.
POPBILL_STATEMENT_ITEM_CODE=121
POPBILL_STATEMENT_MGT_KEY=

